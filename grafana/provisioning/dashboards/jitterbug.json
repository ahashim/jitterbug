    {
      "title": "Cache Misses/sec - Static vs Jitter",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "misses/sec",
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "ops",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "static" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "jitter" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(cache_misses_total{mode=\"static\"}[5s])",
          "legendFormat": "static",
          "refId": "A"
        },
        {
          "expr": "rate(cache_misses_total{mode=\"jitter\"}[5s])",
          "legendFormat": "jitter",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Cache Miss Ratio - Static vs Jitter",
      "description": "Fraction of requests that are cache misses. Static should spike periodically to near 100%, jitter should stay low and flat.",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "miss ratio",
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "min": 0,
          "unit": "percentunit"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "static" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "jitter" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(cache_misses_total{mode=\"static\"}[5s]) / (rate(cache_misses_total{mode=\"static\"}[5s]) + rate(cache_hits_total{mode=\"static\"}[5s]))",
          "legendFormat": "static",
          "refId": "A"
        },
        {
          "expr": "rate(cache_misses_total{mode=\"jitter\"}[5s]) / (rate(cache_misses_total{mode=\"jitter\"}[5s]) + rate(cache_hits_total{mode=\"jitter\"}[5s]))",
          "legendFormat": "jitter",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
