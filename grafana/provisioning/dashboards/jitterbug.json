    {
      "title": "Cache Misses/sec - Static TTL",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "misses/sec",
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 40,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "ops",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(cache_misses_total{mode=\"static\"}[5s])",
          "legendFormat": "misses/s (static)",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
